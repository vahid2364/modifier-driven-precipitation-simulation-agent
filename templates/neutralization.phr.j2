# =============================================================================
# PHREEQC input: NaOH neutralization of {{ leachate.name }} leachate
# Modifier: {{ modifier.name }} @ {{ modifier.dose_mol }} mol/kgw
# NaOH dose: {{ neutralization.naoh_dose_mol }} mol in {{ neutralization.steps }} steps
# Generated by: generate_input.py
# =============================================================================

KNOBS
    -iterations         {{ knobs.iterations }}
    -convergence_tolerance {{ knobs.convergence_tolerance }}
    -tolerance          {{ knobs.tolerance }}
    -logfile true

# =============================================================================
# STAGE 1: Leaching + modifier complexation
# Modifier added as fully deprotonated master species
# =============================================================================

SOLUTION 1 leachate_with_modifier
    temp    {{ leachate.temperature_C }}
    pH      7 charge
    water   {{ leachate.water_kg }}
    units   {{ leachate.units }}
    Al      {{ leachate.composition.Al2_SO4_3 * 2 }}
    Fe      {{ leachate.composition.FeSO4_7H2O }}
    Cu      {{ leachate.composition.CuSO4 }}
    Co      {{ leachate.composition.CoSO4_7H2O }}
    Ni      {{ leachate.composition.NiSO4_6H2O }}
    Mn      {{ leachate.composition.MnSO4_H2O }}
    S(6)    {{ leachate.composition.Al2_SO4_3 * 3 + leachate.composition.FeSO4_7H2O + leachate.composition.CuSO4 + leachate.composition.CoSO4_7H2O + leachate.composition.NiSO4_6H2O + leachate.composition.MnSO4_H2O }}
    {{ modifier.phreeqc_element }}    {{ modifier.dose_mol }}
    Na      {{ modifier.na_counter_ions }}    # Na+ counter-ions from sodium salt form

SELECTED_OUTPUT
    -file           leaching.csv
    -reset          true
    -pH             true
    -pe             true
    -ionic_strength true
    -temperature    true
    -totals         Al Fe Cu Co Ni Mn S Na {{ modifier.phreeqc_element }}
    -molalities     Al+3 Fe+2 Fe+3 Cu+2 Co+2 Ni+2 Mn+2 {{ modifier.selected_molalities }}

SAVE SOLUTION 1
END

# =============================================================================
# STAGE 2: Neutralization — incremental NaOH addition with phase equilibrium
# =============================================================================

USE SOLUTION 1

EQUILIBRIUM_PHASES 1
{% for phase in equilibrium_phases %}
{% if phase.startswith("O2") %}
    {{ phase }}    -0.678  {{ o2_reservoir_mol }}
{% else %}
    {{ phase }}     0.0  0.0
{% endif %}
{% endfor %}

REACTION 2
    NaOH    1.0
    0.0  {% for i in range(1, neutralization.steps + 1) %}{{ "%.4f"|format(neutralization.naoh_dose_mol * i / neutralization.steps) }} {% endfor %}

SELECTED_OUTPUT
    -file           neutralization.csv
    -reset          true
    -pH             true
    -pe             true
    -ionic_strength true
    -temperature    true
    -totals         Al Fe Cu Co Ni Mn Na S {{ modifier.phreeqc_element }}
    -molalities     Al+3 Fe+2 Fe+3 Cu+2 Co+2 Ni+2 Mn+2 {{ modifier.selected_molalities }}
    -equilibrium_phases {% for phase in equilibrium_phases %}{{ phase }} {% endfor %}
    -saturation_indices {% for phase in equilibrium_phases %}{{ phase }} {% endfor %}

END
